{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TonerTrack": "Information"
    }
  },

  "AllowedHosts": "*",

  "Persistence": {
    "DataDirectory": "data",
    "DatabaseFileName": "printers.json",
    "AuditLogFileName": "printers_audit.log"
  },

  "Polling": {
    "Enabled": true,
    "IntervalSeconds": 300,
    "InitialDelaySeconds": 30
  },

  "NinjaRmm": {
    "BaseUrl": "https://app.ninjarmm.com/",
    "ClientId": "",
    "ClientSecret": "",
    "Scope": "monitoring management control offline_access",

    "Ticketing": {
      "ClientId": 0,
      "TicketFormId": 1,
      "LocationId": 1,
      "NodeId": 0
    }
  }
}
